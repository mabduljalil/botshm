{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/scan?mode=daily",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.12",
      "excludeFiles": "{tests/**,__tests__/**,**/*.test.py,**/test_*.py,fixtures/**,__fixtures__/**,testdata/**,sample-data/**,static/**,assets/**}"
    }
  }
}
